# -------------------------------
# GLM core
# -------------------------------
GLM_API_KEY=sk-9d6fdeab8ff548769faf741a3c978796
GLM_PROVIDER=auto
GLM_MODEL=glm-5
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_TIMEOUT_SEC=60
GLM_MAX_RETRIES=2

# -------------------------------
# OpenAI (optional, native via OpenAI SDK)
# If set, OPENAI_* can be reused by GLM client as fallback.
# To force OpenAI only:
#   GLM_PROVIDER=openai_compat
#   GLM_BASE_URL=https://api.openai.com/v1
#   GLM_MODEL=gpt-5-mini
# -------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_PROVIDER=openai_compat

# -------------------------------
# Companion RAG
# mode: embedding | keyword | hybrid
# -------------------------------
RAG_MODE=hybrid
RAG_EMBED_MODEL=BAAI/bge-small-zh-v1.5
RAG_INDEX_PATH=monitor/companion_rag.faiss
RAG_DOCS_PATH=monitor/companion_rag_docs.json
RAG_HYBRID_EMBED_WEIGHT=0.7
RAG_HYBRID_KEYWORD_WEIGHT=0.3
RAG_CORRECTIVE_ENABLED=1
RAG_CORRECTIVE_MIN_SCORE=0.08
RAG_ITERATIVE_ENABLED=1
RAG_ITERATIVE_MAX_QUERIES=2
RAG_CANDIDATE_POOL_SIZE=8
RAG_DIVERSITY_ENABLED=1
RAG_DIVERSITY_MIN_JACCARD_GAP=0.08
RAG_DEBUG=0
RAG_SELF_ENABLED=1
RAG_SELF_MIN_QUERY_CHARS=3
RAG_SELF_SECOND_PASS_ENABLED=1
RAG_SELF_SECOND_PASS_MIN_TOP_SCORE=0.26

# optional for unlabeled video conversational training scripts
RAG_VIDEO_TRANSCRIBE=0

# -------------------------------
# Runtime
# -------------------------------
CHAT_DB_PATH=monitor/metrics.db
STATE_PATH=state.json
IDLE_CHECK_INTERVAL=1.0
IDLE_SECONDS=20
NUDGE_COOLDOWN_SEC=90
MAX_NUDGES=3
RAG_TOP_K=4
MEMORY_TOP_K=4
MAX_TURNS=6
MEMORY_FIRST_ENABLED=1
MEMORY_FIRST_STRICT=0
PERSONA_PROFILE=aphrodite
AUTO_PERSONA_ENABLED=1
PERSONA_SWITCH_MIN_CONFIDENCE=0.62
PERSONA_SWITCH_COOLDOWN_TURNS=2
FULL_USER_PERMISSIONS=1
SCREEN_CAPTURE_ENABLED=1
SCREEN_CAPTURE_DIR=monitor/screenshots
IDE_WATCH_ENABLED=0
IDE_DEBUG_LOG_PATH=monitor/ide_debug.log
IDE_WATCH_POLL_INTERVAL_SEC=1.5
IDE_WATCH_EMIT_COOLDOWN_SEC=8.0
IDE_AUTO_FIX_ENABLED=0
IDE_AUTO_FIX_ROUNDS=1
IDE_AUTO_FIX_COOLDOWN_SEC=15.0
IDE_AUTO_FIX_ONLY_WORKSPACE=1
IDE_AUTOPILOT_ENABLED=0
IDE_AUTOPILOT_COMMAND=
IDE_AUTOPILOT_INTERVAL_SEC=12.0
IDE_AUTOPILOT_TIMEOUT_SEC=120.0
NL_INTENT_ECHO_ENABLED=0
PROMPT_SELF_EDIT_ENABLED=1
PROMPT_AUTO_IMPROVE_ON_FEEDBACK=1
SELFDRIVE_SEMANTIC_ENABLED=1
SELFDRIVE_SEMANTIC_MIN_CONFIDENCE=0.72
SELFDRIVE_HEARTBEAT_SEC=30
FORCE_ONE_SENTENCE_OUTPUT=0
REPLY_MAX_SENTENCES=3
REPLY_MAX_CHARS=180
TTS_FILLER_ENABLED=1
AUTO_WEB_SEARCH_ENABLED=0
AUTO_WEB_SEARCH_MAX_RESULTS=3
AUTO_WEB_SEARCH_CACHE_TTL_SEC=3600

# -------------------------------
# Azure Speech (optional)
# -------------------------------
AZURE_TTS_ENABLED=0
AZURE_STT_ENABLED=0
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_TTS_OUTPUT_FORMAT=riff-24khz-16bit-mono-pcm
AZURE_STT_LANGUAGE=zh-CN
AZURE_TTS_SAVE_PATH=monitor/tts_last.wav

SSML_VOICE=zh-CN-XiaoxiaoNeural
SSML_STYLE=newscast
SSML_STYLEDEGREE=0.6
SSML_ROLE=
SSML_VOLUME=default
SSML_LANG=zh-CN
SSML_USE_MSTTS=1

# -------------------------------
# Advanced Decision (reserved; off by default)
# -------------------------------
ADV_DECISION_ENABLED=0
ADV_DECISION_SAMPLES=3
ADV_DECISION_BASE_TEMP=0.8
ADV_DECISION_TEMP_STEP=0.12
ADV_DECISION_DIVERGENCE_HIGH=0.35
ADV_DECISION_UNCERTAINTY_HIGH=0.60
ADV_DECISION_CRITIC_ENABLED=1
