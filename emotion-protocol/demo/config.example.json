{
  "version": "1.0",
  "engine": {
    "tickRate": 100,
    "maxConcurrentEmotions": 5,
    "defaultDecayRate": 0.02
  },
  "emotions": {
    "joy": {
      "baseIntensity": 0.5,
      "decayRate": 0.015,
      "defaultDuration": 8000,
      "cooldown": 2000,
      "valence": 0.8,
      "arousal": 0.6,
      "color": "#ffd700",
      "emoji": "😊"
    },
    "sadness": {
      "baseIntensity": 0.4,
      "decayRate": 0.008,
      "defaultDuration": 15000,
      "cooldown": 15000,
      "valence": -0.7,
      "arousal": -0.4,
      "color": "#4a90e2",
      "emoji": "😢"
    },
    "anger": {
      "baseIntensity": 0.5,
      "decayRate": 0.012,
      "defaultDuration": 10000,
      "cooldown": 30000,
      "valence": -0.6,
      "arousal": 0.8,
      "color": "#e74c3c",
      "emoji": "😠"
    },
    "surprise": {
      "baseIntensity": 0.6,
      "decayRate": 0.05,
      "defaultDuration": 3000,
      "cooldown": 5000,
      "valence": 0.3,
      "arousal": 0.9,
      "color": "#9b59b6",
      "emoji": "😲"
    },
    "fear": {
      "baseIntensity": 0.4,
      "decayRate": 0.02,
      "defaultDuration": 8000,
      "cooldown": 10000,
      "valence": -0.8,
      "arousal": 0.7,
      "color": "#2c3e50",
      "emoji": "😨"
    },
    "disgust": {
      "baseIntensity": 0.4,
      "decayRate": 0.015,
      "defaultDuration": 6000,
      "cooldown": 8000,
      "valence": -0.9,
      "arousal": 0.5,
      "color": "#27ae60",
      "emoji": "🤢"
    },
    "neutral": {
      "baseIntensity": 0.1,
      "decayRate": 0.0,
      "defaultDuration": 0,
      "cooldown": 0,
      "valence": 0.0,
      "arousal": 0.1,
      "color": "#95a5a6",
      "emoji": "😐"
    },
    "love": {
      "baseIntensity": 0.5,
      "decayRate": 0.01,
      "defaultDuration": 12000,
      "cooldown": 5000,
      "valence": 0.9,
      "arousal": 0.5,
      "color": "#ff69b4",
      "emoji": "😍"
    },
    "excitement": {
      "baseIntensity": 0.6,
      "decayRate": 0.03,
      "defaultDuration": 6000,
      "cooldown": 3000,
      "valence": 0.85,
      "arousal": 0.9,
      "color": "#ff1493",
      "emoji": "🤩"
    },
    "anxiety": {
      "baseIntensity": 0.4,
      "decayRate": 0.025,
      "defaultDuration": 10000,
      "cooldown": 12000,
      "valence": -0.5,
      "arousal": 0.7,
      "color": "#ff8c00",
      "emoji": "😰"
    }
  },
  "rules": [
    {
      "id": "praise_triggers_joy",
      "name": "赞美触发开心",
      "from": "*",
      "to": "joy",
      "trigger": ["user_message"],
      "conditions": {
        "payloadContains": ["棒", "好", "开心", "高兴", "谢谢", "great", "amazing", "awesome"]
      },
      "effect": {
        "addIntensity": 0.3,
        "duration": 8000
      }
    },
    {
      "id": "sad_message_triggers_sadness",
      "name": "悲伤消息触发悲伤",
      "from": "*",
      "to": "sadness",
      "trigger": ["user_message"],
      "conditions": {
        "payloadContains": ["难过", "伤心", "sad", "unhappy", "哭", "泪"]
      },
      "effect": {
        "addIntensity": 0.3,
        "duration": 15000
      }
    },
    {
      "id": "angry_message_triggers_anger",
      "name": "愤怒消息触发愤怒",
      "from": "*",
      "to": "anger",
      "trigger": ["user_message"],
      "conditions": {
        "payloadContains": ["生气", "愤怒", "angry", "mad", "恨", "可恶"]
      },
      "effect": {
        "addIntensity": 0.5,
        "duration": 10000
      }
    },
    {
      "id": "unexpected_triggers_surprise",
      "name": "意外触发惊讶",
      "from": "*",
      "to": "surprise",
      "trigger": ["environment_change", "user_message"],
      "conditions": {
        "payloadContains": ["惊讶", "哇", "wow", "surprise", "unexpected", "没想到"]
      },
      "effect": {
        "addIntensity": 0.6,
        "duration": 3000
      }
    },
    {
      "id": "love_expression_triggers_love",
      "name": "爱意表达触发喜爱",
      "from": "*",
      "to": "love",
      "trigger": ["user_message"],
      "conditions": {
        "payloadContains": ["爱", "love", "喜欢", "like", "❤", "💕"]
      },
      "effect": {
        "addIntensity": 0.5,
        "duration": 12000
      }
    },
    {
      "id": "fear_message_triggers_fear",
      "name": "恐惧消息触发恐惧",
      "from": "*",
      "to": "fear",
      "trigger": ["user_message"],
      "conditions": {
        "payloadContains": ["害怕", "恐惧", "scared", "fear", "恐怖", "吓人"]
      },
      "effect": {
        "addIntensity": 0.4,
        "duration": 8000
      }
    },
    {
      "id": "positive_memory_triggers_joy",
      "name": "积极记忆触发开心",
      "from": "*",
      "to": "joy",
      "trigger": ["memory_recall"],
      "conditions": {
        "valence": "positive"
      },
      "effect": {
        "addIntensity": 0.3,
        "duration": 8000
      }
    },
    {
      "id": "negative_memory_triggers_sadness",
      "name": "消极记忆触发悲伤",
      "from": "*",
      "to": "sadness",
      "trigger": ["memory_recall"],
      "conditions": {
        "valence": "negative"
      },
      "effect": {
        "addIntensity": 0.4,
        "duration": 15000
      }
    },
    {
      "id": "morning_mood_boost",
      "name": "早晨心情提升",
      "from": "*",
      "to": "joy",
      "trigger": ["time_event"],
      "conditions": {
        "timeOfDay": "morning"
      },
      "effect": {
        "addIntensity": 0.2,
        "duration": 5000
      }
    },
    {
      "id": "night_mood_dip",
      "name": "夜晚心情低落",
      "from": "*",
      "to": "sadness",
      "trigger": ["time_event"],
      "conditions": {
        "timeOfDay": "night"
      },
      "effect": {
        "addIntensity": 0.15,
        "duration": 10000
      }
    }
  ],
  "compatibility": {
    "joy+excitement": 0.95,
    "joy+sadness": 0.3,
    "anger+love": 0.1,
    "fear+surprise": 0.8,
    "disgust+joy": 0.05,
    "love+joy": 0.9,
    "anger+fear": 0.4,
    "sadness+fear": 0.6,
    "surprise+joy": 0.7,
    "surprise+fear": 0.8
  },
  "expressions": {
    "defaultAdapter": "console",
    "adapters": {
      "console": {
        "enabled": true,
        "showEmoji": true,
        "showBars": true
      },
      "live2d": {
        "enabled": false,
        "modelPath": "models/character.vrm",
        "expressionPrefix": "exp_"
      },
      "vrm": {
        "enabled": false,
        "modelPath": "models/character.vrm",
        "blendShapePrefix": "blendShape1."
      }
    }
  }
}
